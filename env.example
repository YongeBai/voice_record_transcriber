# Copy this file to .env and fill in the secrets below.
#
# Simplenote credentials:
SIMPLENOTE_USER=your-email@example.com
SIMPLENOTE_PASSWORD=your-password
#
# Soniox API credentials:
SONIOX_API_KEY=your-soniox-api-key
#
# Optional Soniox tuning:
# SONIOX_MODEL=stt-async-v4
# SONIOX_LANGUAGE_HINTS=en
# SONIOX_CONTEXT_TEXT=Personal voice memos and reminders.
#
# Optional device overrides:
# VOICE_MEMO_USER=yongebai
# VOICE_MEMO_MOUNT_PATHS=/media/yongebai/L87
#
# Optional behavior:
# VOICE_MEMO_TAG=voice-memo
# VOICE_MEMO_BOOTSTRAP_THRESHOLD=20
# VOICE_MEMO_POLL_INTERVAL_SECONDS=2
# VOICE_MEMO_TIMEOUT_SECONDS=1800
